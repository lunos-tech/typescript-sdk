{
  "name": "@lunos/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Lunos AI API gateway",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lunos",
    "ai",
    "api",
    "sdk",
    "openai",
    "chat",
    "completions",
    "embeddings",
    "tts",
    "image-generation"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "5.7.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=18"
  }
}
